<ProduitsScreen>:
    name: 'produits_screen'
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: 0.98, 0.98, 0.98, 1
        
        MDTopAppBar:
            title: "Nos Produits"
            md_bg_color: 0.1, 0.15, 0.2, 1
            left_action_items: [["arrow-left", lambda x: getattr(root, 'go_back')()]]
            
        MDScrollView:
            MDBoxLayout:
                orientation: 'vertical'
                adaptive_height: True
                padding: "20dp"
                spacing: "15dp"
                
                MDLabel:
                    text: "📦 Produit Luxe A"
                    font_style: "H6"
                MDLabel:
                    text: "📦 Produit Luxe B"
                    font_style: "H6"
                    
        MDFloatLayout:
            size_hint_y: None
            height: "70dp"
            MDRaisedButton:
                text: "Configuration"
                md_bg_color: 0.1, 0.15, 0.2, 1
                pos_hint: {"center_x": .5, "center_y": 0.5}
                on_release: root.manager.current = 'parametres_screen'