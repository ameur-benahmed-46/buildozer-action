ScreenManager:
    MainScreen:

<MainScreen>:
    name: 'main'
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: 0.98, 0.98, 0.98, 1
        
        MDTopAppBar:
            title: "Application Premium"
            md_bg_color: 0.1, 0.15, 0.2, 1
            
        MDFloatLayout:
            MDLabel:
                text: "Interface en Temps Reel !"
                halign: "center"
                font_style: "H5"
                pos_hint: {"center_y": 0.6}
                
            MDRaisedButton:
                text: "Bouton Luxueux"
                md_bg_color: 0.1, 0.15, 0.2, 1
                pos_hint: {"center_x": .5, "center_y": 0.45}